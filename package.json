{
  "name": "rss-feed-search-service",
  "version": "0.1.0",
  "private": true,
  "description": "RSS/블로그/뉴스 피드 수집 + 검색 + 요약 저장 시스템 (MVP)",
  "scripts": {
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/main.ts",
    "start:worker": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint '{src,test}/**/*.{ts,js}' --fix",
    "format": "prettier --write '{src,test}/**/*.{ts,js,json,md}'"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^11.0.0",
    "bullmq": "^5.58.5",
    "axios": "^1.13.6",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.8.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.13",
    "rss-parser": "^3.13.0",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/express": "^4.17.20",
    "@types/node": "^20.0.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
